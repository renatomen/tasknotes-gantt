{
  "name": "tasknotes-gantt",
  "version": "0.0.1",
  "private": true,
  "description": "Render SVAR Svelte Gantt charts from note properties and YAML frontmatter, with Bases and TaskNotes integration.",
  "author": "renatomen",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "install:vault": "node scripts/install-to-vault.mjs",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint . --ext .ts,.svelte",
    "typecheck": "svelte-check --tsconfig tsconfig.json",
    "format": "prettier --write .",
    "version": "node version-bump.mjs && node scripts/generate-release-notes-import.mjs && node scripts/update-release-index.mjs && git add manifest.json versions.json src/releaseNotes.ts docs/releases.md",
    "e2e": "wdio run ./test/wdio/wdio.conf.mts",
    "build:local": "vite build",
    "e2e:local": "node scripts/e2e-local.mjs",
    "perf:isolated": "vitest run --config test/perf/vitest.config.ts",
    "perf:gen": "tsx scripts/perf-gen.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@swc/core": "^1.13.5",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@wdio/cli": "^9.19.2",
    "@wdio/globals": "^9.17.0",
    "@wdio/mocha-framework": "^9.19.2",
    "@wdio/types": "^9.19.2",
    "builtin-modules": "^5.0.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.36.0",
    "eslint-plugin-svelte": "^3.12.4",
    "husky": "^9.1.7",
    "jest": "^30.1.3",
    "obsidian": "^1.13.1",
    "playwright": "^1.61.1",
    "prettier": "^3.6.2",
    "svelte": "^5.39.6",
    "svelte-check": "^4.3.2",
    "svelte-eslint-parser": "^1.3.3",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vitest": "^4.1.9",
    "vitest-browser-svelte": "^2.1.1",
    "wdio-obsidian-reporter": "^2.1.2",
    "wdio-obsidian-service": "^2.1.2",
    "webdriverio": "^9.19.2"
  },
  "dependencies": {
    "@svar-ui/svelte-gantt": "^2.7.0"
  }
}
