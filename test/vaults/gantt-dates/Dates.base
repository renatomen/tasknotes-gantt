filters:
  and:
    - 'file.ext == "md"'
views:
  - type: obsidianGantt
    name: "Gantt Dates (show all)"
    tngantt_startDateProperty: note.start
    tngantt_endDateProperty: note.due
    tngantt_progressProperty: note.progress
    tngantt_defaultDuration: 1
    tngantt_showUndatedTasks: true
    tngantt_showPartialDateTasks: true
    tngantt_showDateIndicators: true
    order:
      - file.name
      - note.start
      - note.due
