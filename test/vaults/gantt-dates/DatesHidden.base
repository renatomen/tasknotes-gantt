filters:
  and:
    - 'file.ext == "md"'
views:
  - type: obsidianGantt
    name: "Gantt Dates (hide undated, no indicators)"
    tngantt_startDateProperty: note.start
    tngantt_endDateProperty: note.due
    tngantt_progressProperty: note.progress
    tngantt_defaultDuration: 1
    tngantt_showUndatedTasks: false
    tngantt_showPartialDateTasks: true
    tngantt_showDateIndicators: false
    order:
      - file.name
      - note.start
      - note.due
