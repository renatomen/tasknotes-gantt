filters:
  and:
    - 'file.ext == "md"'
    - 'file.name == "Task Status"'
views:
  - type: obsidianGantt
    name: "Fill Status"
    tngantt_startDateProperty: note.begin
    tngantt_endDateProperty: note.finish
    tngantt_statusProperty: note.status
    tngantt_barFillSource: status
    tngantt_barStripSource: none
    tngantt_defaultScale: day
    tngantt_defaultDuration: 1
    order:
      - file.name
