filters:
  and:
    - 'file.ext == "md"'
    - 'file.name == "Task Tri"'
views:
  - type: obsidianGantt
    name: "Fill Calendar"
    tngantt_startDateProperty: note.begin
    tngantt_endDateProperty: note.finish
    tngantt_calendarProperty: note.calendar
    tngantt_barFillSource: calendar
    tngantt_barStripSource: none
    tngantt_defaultScale: day
    tngantt_defaultDuration: 1
    order:
      - file.name
