filters:
  and:
    - 'file.ext == "md"'
    - 'file.name == "Task Tri"'
views:
  - type: obsidianGantt
    name: "Channels Triple"
    tngantt_startDateProperty: note.begin
    tngantt_endDateProperty: note.finish
    tngantt_calendarProperty: note.calendar
    tngantt_statusProperty: note.status
    tngantt_priorityProperty: note.priority
    tngantt_barFillSource: calendar
    tngantt_barStripSource: priority
    tngantt_barIcon: status
    tngantt_defaultScale: day
    tngantt_defaultDuration: 1
    order:
      - file.name
