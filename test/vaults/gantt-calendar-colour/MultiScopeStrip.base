filters:
  and:
    - 'file.ext == "md"'
    - 'note.start || note.due'
views:
  - type: obsidianGantt
    name: "Multi Scope Strip"
    tngantt_startDateProperty: note.start
    tngantt_endDateProperty: note.due
    tngantt_barFillSource: none
    tngantt_barStripSource: default
    tngantt_defaultScale: day
    tngantt_defaultDuration: 1
    order:
      - file.name
