filters:
  and:
    - 'file.ext == "md"'
views:
  - type: obsidianGantt
    name: "Gantt (OG) themed"
    tngantt_startDateProperty: note.start
    tngantt_endDateProperty: note.due
    tngantt_progressProperty: note.progress
    tngantt_parentProperty: note.parent
    tngantt_dependencyArrowMode: primary
    tngantt_defaultScale: month
    tngantt_barFillSource: theme
    order:
      - file.name
      - note.start
      - note.due
      - note.progress
