filters:
  and:
    - 'file.ext == "md"'
views:
  - type: obsidianGantt
    name: "Gantt (OG)"
    startDateProperty: note.start
    endDateProperty: note.due
    progressProperty: note.progress
    parentProperty: note.parent
    dependencyArrowMode: primary
    defaultScale: month
    order:
      - file.name
      - note.start
      - note.due
      - note.progress
