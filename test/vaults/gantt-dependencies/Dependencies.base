filters:
  and:
    - 'file.ext == "md"'
views:
  - type: obsidianGantt
    name: "Gantt (OG)"
    tngantt_startDateProperty: note.scheduled
    tngantt_endDateProperty: note.due
    tngantt_parentProperty: note.parent
    tngantt_dependencyArrowMode: primary
    order:
      - file.name
      - note.scheduled
      - note.due
