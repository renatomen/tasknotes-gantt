# Obsidian Gantt Plugin - Environment Configuration

# SECURITY WARNING
# Never commit actual credentials to version control
# Add .env to .gitignore to prevent accidental commits

# Setup Instructions:
# 1. Copy this file to .env
# 2. Replace example values with your actual paths
# 3. Ensure .env is listed in .gitignore

# ============================================================================
# TEST VAULT CONFIGURATION
# ============================================================================

# Path to your local Obsidian test vault
# This is used by build scripts to install the plugin for testing
# Set this to your local vault path - each machine can have a different path
#
# Windows example:
# OBSIDIAN_TEST_VAULT=C:/Users/your-name/OneDrive/@-Notes/Vaults/obsidian-gantt
#
# WSL/Linux example:
# OBSIDIAN_TEST_VAULT=/home/your-name/obsidian-test-vaults/obsidian-gantt-test-vault
#
# Or access Windows filesystem from WSL:
# OBSIDIAN_TEST_VAULT=/mnt/c/Users/your-name/OneDrive/@-Notes/Vaults/obsidian-gantt
#
# Leave empty to use platform-specific defaults
OBSIDIAN_TEST_VAULT=
