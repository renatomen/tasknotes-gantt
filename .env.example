# Obsidian Gantt Plugin - Environment Configuration
# AssertThat BDD Integration Settings

# ============================================================================
# SECURITY WARNING
# ============================================================================
# Never commit actual credentials to version control
# Add .env to .gitignore (already configured)
# Keep your API tokens and keys secure

# ============================================================================
# Setup Instructions:
# ============================================================================
# 1. Copy this file to .env
# 2. Replace example values with your actual credentials and paths
# 3. Restart your development environment

# ============================================================================
# Jira Configuration
# ============================================================================

# Your Jira instance URL
# Example: https://your-company.atlassian.net
JIRA_BASE_URL=https://your-domain.atlassian.net

# Your Atlassian account email
JIRA_EMAIL=your-email@example.com

# Jira API Token
# Generate from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-api-token-here

# ============================================================================
# AssertThat BDD Configuration
# ============================================================================

# AssertThat access key from Jira app configuration
# Find in: Jira Settings > Apps > AssertThat BDD > Configuration
ASSERTTHAT_ACCESS_KEY=your-access-key-here

# AssertThat secret key from Jira app configuration
ASSERTTHAT_SECRET_KEY=your-secret-key-here

# AssertThat project ID
# Find in your Jira project settings or AssertThat configuration
ASSERTTHAT_PROJECT_ID=10000

# ============================================================================
# Optional Configuration
# ============================================================================

# Optional: Enable debug logging
# Set to 'true' to enable detailed logging for BDD upload operations
DEBUG_BDD_UPLOAD=false

# Optional: Custom upload timeout
# Timeout in milliseconds for API requests (default: 30000)
UPLOAD_TIMEOUT_MS=30000

# ============================================================================
# TEST VAULT CONFIGURATION
# ============================================================================

# OPTIONAL: path to your local Obsidian vault for manual checking.
# When set to an existing vault, every build (vite build / npm run build / dev
# --watch) installs the plugin into <vault>/.obsidian/plugins/tasknotes-gantt/.
# Each machine can use a different path; this file is gitignored, so it stays local.
#
# Windows example:
# OBSIDIAN_TEST_VAULT=C:/Users/your-name/OneDrive/@-Notes/Vaults/obsidian-gantt
#
# WSL/Linux example:
# OBSIDIAN_TEST_VAULT=/home/your-name/obsidian-test-vaults/obsidian-gantt-test-vault
#
# Or access Windows filesystem from WSL:
# OBSIDIAN_TEST_VAULT=/mnt/c/Users/your-name/OneDrive/@-Notes/Vaults/obsidian-gantt
#
# Leave empty (or unset) to skip the vault install — the build still succeeds.
OBSIDIAN_TEST_VAULT=
