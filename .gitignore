# Node / package managers
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs / coverage
/dist/
/coverage/
.eslintcache

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Test & E2E artifacts
.test-results/
.wdio-*

# Local-only e2e probes (point at private vaults; never commit)
test/specs/_local-*

# Demo-capture scratch output (approved images are moved into docs/media/)
.demo-out/

# Riffrec product-feedback raw media & extracted frames — local-only by default
# (the markdown analysis/requirements artifacts alongside them ARE committed).
docs/brainstorms/riffrec-feedback/**/raw/
docs/brainstorms/riffrec-feedback/**/frames/

# #161 U6 "vault as code" DATA artifacts — derived from a private vault (real
# frontmatter; TaskNotes secrets are redacted, but structure stays private until a
# commit/privacy decision). The GENERATOR (scripts/vault-as-code.mjs) is committed;
# regenerate locally with it. Do not commit these.
test/fixtures/maintest.vaultcode.json
test/fixtures/maintest-profile.json

# Stray obsidian-launcher cache that can land at repo root (vs the wdio one below)
/.obsidian-cache/

# Env files (if used)
.env
.env.*
!.env.example

# Obsidian local config / E2E cache
.obsidian/
test/wdio/.obsidian-cache/

# Compound Engineering — local agent tooling/config (incl. the example template);
# not useful in the public repo. The plugin only reads the machine-local
# config.local.yaml, which never leaves the machine anyway.
.compound-engineering/

# Claude Code personal settings (machine-local)
.claude/settings.local.json

# Installed/fetched agent skills (reproduced from skills-lock.json)
.agents/skills/
.claude/skills/

# Perf-harness runtime trend artifacts (uploaded by CI, never committed)
test/perf/.trend/

# Vitest browser-mode artifacts (screenshots/attachments from failing runs)
test/perf/**/__screenshots__/
.vitest-attachments/

# probe run artifacts (generated)
test/probe/.results/
test/probe/__screenshots__/

# MkDocs build output (docs site is built in CI and deployed to Pages)
website/site/
docs/media/_shots/

# Design mocks — local visual explorations, not shipped assets
docs/mocks/
