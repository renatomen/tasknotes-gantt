# Node / package managers
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs / coverage
/dist/
/coverage/
.eslintcache

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Test & E2E artifacts
.test-results/
.wdio-*

# Env files (if used)
.env
.env.*
!.env.example

# Obsidian local config / E2E cache
.obsidian/
test/wdio/.obsidian-cache/

# AssertThat sync staging area
featureSyncStage/

# Compound Engineering machine-local config
.compound-engineering/*.local.yaml

# Claude Code personal settings (machine-local)
.claude/settings.local.json

# Installed/fetched agent skills (reproduced from skills-lock.json)
.agents/skills/
.claude/skills/

# Perf-harness runtime trend artifacts (uploaded by CI, never committed)
test/perf/.trend/

# Vitest browser-mode artifacts (screenshots/attachments from failing runs)
test/perf/**/__screenshots__/
.vitest-attachments/
